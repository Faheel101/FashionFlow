# =============================================================================
# FashionFlow — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Cloud / BigQuery
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=US
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# BigQuery dataset names
BQ_DATASET_RAW=fashionflow_raw
BQ_DATASET_STAGING=fashionflow_staging
BQ_DATASET_MART=fashionflow_mart

# -----------------------------------------------------------------------------
# Source System — FastAPI
# -----------------------------------------------------------------------------
SOURCE_API_HOST=127.0.0.1
SOURCE_API_PORT=8000
SOURCE_API_KEY=fashionflow-dev-api-key-change-me

# SQLite database path (relative to project root)
SOURCE_DB_PATH=data/fashionflow.db

# -----------------------------------------------------------------------------
# dlt — Ingestion
# -----------------------------------------------------------------------------
DLT_PIPELINE_NAME=fashionflow_commerce
DLT_DESTINATION=bigquery

# -----------------------------------------------------------------------------
# dbt — Transformations
# -----------------------------------------------------------------------------
DBT_PROJECT_DIR=transformations
DBT_PROFILES_DIR=transformations
DBT_TARGET=dev

# -----------------------------------------------------------------------------
# Dagster — Orchestration
# -----------------------------------------------------------------------------
DAGSTER_HOME=.dagster
